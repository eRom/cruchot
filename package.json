{
  "name": "cruchot",
  "version": "0.5.4",
  "description": "Cruchot — Chat multi-provider avec support OpenAI, Anthropic, Gemini, Mistral, xAI, OpenRouter, Ollama, LM Studio",
  "main": "./out/main/index.js",
  "author": "Romain",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:publish": "electron-vite build && electron-builder --mac --win --linux --publish always",
    "release": "npm version patch && git push && git push --tags",
    "dev:web": "vite --config src/remote-web/vite.config.ts",
    "build:web": "vite build --config src/remote-web/vite.config.ts",
    "deploy:web": "npm run build:web && cd out/remote-web && npx vercel --prod"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/xai": "^3.0.67",
    "@huggingface/transformers": "^3.8.1",
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "@perplexity-ai/ai-sdk": "^0.1.2",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-virtual": "^3.13.21",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "drizzle-orm": "^0.39.0",
    "electron-updater": "^6.3.0",
    "hotkeys-js": "^4.0.2",
    "i18next": "^25.8.16",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "mermaid": "^11.13.0",
    "nanoid": "^5.1.6",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "react-i18next": "^16.5.6",
    "react-is": "^19.2.4",
    "react-markdown": "^9.1.0",
    "recharts": "^3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "trash": "^10.1.1",
    "turndown": "^7.2.2",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/pdf-parse": "^1.1.5",
    "@types/plist": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "terser": "^5.46.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
